{
  "annotations": {
    "list": []
  },
  "description": "ADP Platform Observability — Pipeline runs, agent dispatch, governance events",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "L01 — Pipeline Telemetry",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Pipeline Runs (Total)",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_runs",
          "legendFormat": "{{pipeline}} — {{passed}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Pipeline Stage Runs",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_stage_runs",
          "legendFormat": "{{pipeline}}/{{stage}} — {{passed}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "title": "Dispatch Cycle Duration",
      "type": "stat",
      "targets": [
        {
          "expr": "dispatch_cycle_duration_ms_sum / dispatch_cycle_duration_ms_count",
          "legendFormat": "avg duration"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "title": "L02 — Dispatch Work",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 11,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Work Items Assigned",
      "type": "stat",
      "targets": [
        {
          "expr": "dispatch_assignments",
          "legendFormat": "{{type}} → {{agent}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Escalations",
      "type": "stat",
      "targets": [
        {
          "expr": "dispatch_escalations",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "id": 13,
      "title": "Queue Size",
      "type": "gauge",
      "targets": [
        {
          "expr": "dispatch_queue_size",
          "legendFormat": "queue depth"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "L03 — GOVERNANCE Events",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Governance Events by Action",
      "type": "stat",
      "targets": [
        {
          "expr": "governance_events",
          "legendFormat": "{{action}} ({{path}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "title": "Governance Denials",
      "type": "stat",
      "targets": [
        {
          "expr": "dispatch_governance_denials",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["adp", "platform-engineering", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ADP Platform Observability",
  "uid": "adp-observability",
  "version": 1
}
